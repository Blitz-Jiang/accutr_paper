@article{nesterovImplementableTensorMethods2021,
  title    = {Implementable tensor methods in unconstrained convex optimization},
  volume   = {186},
  issn     = {1436-4646},
  url      = {https://doi.org/10.1007/s10107-019-01449-1},
  doi      = {10.1007/s10107-019-01449-1},
  abstract = {In this paper we develop new tensor methods for unconstrained convex optimization, which solve at each iteration an auxiliary problem of minimizing convex multivariate polynomial. We analyze the simplest scheme, based on minimization of a regularized local model of the objective function, and its accelerated version obtained in the framework of estimating sequences. Their rates of convergence are compared with the worst-case lower complexity bounds for corresponding problem classes. Finally, for the third-order methods, we suggest an efficient technique for solving the auxiliary problem, which is based on the recently developed relative smoothness condition (Bauschke et al. in Math Oper Res 42:330–348, 2017; Lu et al. in SIOPT 28(1):333–354, 2018). With this elaboration, the third-order methods become implementable and very fast. The rate of convergence in terms of the function value for the accelerated third-order scheme reaches the level \$\$O{\textbackslash}left( \{1 {\textbackslash}over k{\textasciicircum}4\}{\textbackslash}right) \$\$, where k is the number of iterations. This is very close to the lower bound of the order \$\$O{\textbackslash}left( \{1 {\textbackslash}over k{\textasciicircum}5\}{\textbackslash}right) \$\$, which is also justified in this paper. At the same time, in many important cases the computational cost of one iteration of this method remains on the level typical for the second-order methods.},
  language = {en},
  number   = {1},
  urldate  = {2024-11-13},
  journal  = {Mathematical Programming},
  author   = {Nesterov, Yurii},
  month    = mar,
  year     = {2021},
  keywords = {65K05, 90C06, 90C25, Convex optimization, Lower complexity bounds, Tensor methods, High-order methods, Worst-case complexity bounds},
  pages    = {157--183},
  file     = {Full Text PDF:/Users/brent/Zotero/storage/SFALYSWU/Nesterov - 2021 - Implementable tensor methods in unconstrained convex optimization.pdf:application/pdf}
}

